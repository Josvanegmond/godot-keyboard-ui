; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[accessibility]

general/accessibility_support=1

[application]

config/name="godot-keyboard-ui.git"
run/main_scene="uid://b8cuvqgwqosfv"
config/features=PackedStringArray("4.7", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

UIAudio="*uid://d22n2ty5bs3e"
SpeechService="*uid://daluu8g3t8kdk"
StorageService="*uid://dacpkug5cysab"
SpeechNodeService="*uid://kf543t4y36ik"

[editor_plugins]

enabled=PackedStringArray("res://addons/keyboard_ui/plugin.cfg")

[file_customization]

folder_colors={
"res://addons/keyboard_ui/storage/": "yellow"
}

[gui]

theme/custom="uid://cc87qxdn88waw"

[input]

stop_speech={
"deadzone": 0.2,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":0,"physical_keycode":4194325,"key_label":0,"unicode":0,"location":0,"echo":false,"script":null)
]
}

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

rendering_device/driver.windows="d3d12"
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
